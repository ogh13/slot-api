# Exemple de fichier d’environnement
# Copiez ce fichier en .env et ajustez les valeurs.

# Connexion à la base de données PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/slotapi

# Connexion à la base de données PostgreSQL pour les tests
TEST_DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/test_slotapi

# Connexion à Redis
REDIS_URL=redis://localhost:6379

# Clé secrète de l'API
API_KEY=change-me-to-a-secure-random-string

# URL interne de l'API, utilisée par le worker pour appeler le webhook interne
API_BASE_URL=http://localhost:8000